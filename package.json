{
  "name": "phimp",
  "version": "0.0.1",
  "description": "Detect phantom (hallucinated) imports in JS/TS projects",
  "bin": {
    "phimp": "dist/cli.js"
  },
  "type": "module",
  "main": "dist/cli.js",
  "scripts": {
    "build": "bun run type && esbuild src/cli.ts --bundle --packages=external --minify --sourcemap --format=esm --target=node22 --outfile=dist/cli.js --banner:js='#!/usr/bin/env node'",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "type": "tsc --declaration --emitDeclarationOnly"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.4",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
